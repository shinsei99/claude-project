# =====================================================================
#  AI受付＆起票カウンター  環境変数テンプレート
#  このファイルを `.env` にコピーして値を埋めてください（.env は Git 管理しない）
#    cp .env.example .env
# =====================================================================

# ── AI 解析（claude CLI） ────────────────────────────────────────────
# 既存アプリと同じく ~/.local/bin/claude を使用。APIキーは不要。
CLAUDE_BIN=~/.local/bin/claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT=300

# ── 起票先の選択 ────────────────────────────────────────────────────
# github / notion / backlog / excel のいずれか（環境に合わせて変更可）
TICKET_BACKEND=github

# --- GitHub Issues（TICKET_BACKEND=github のとき） ---
# gh CLI 認証済みならトークン不要。owner/repo だけ指定。
GITHUB_REPO=shinsei99/project
# gh CLI を使わず REST API を叩く場合のみ設定（任意）
GITHUB_TOKEN=

# --- Notion（TICKET_BACKEND=notion のとき） ---
NOTION_TOKEN=
NOTION_DATABASE_ID=

# --- Backlog（TICKET_BACKEND=backlog のとき） ---
BACKLOG_SPACE=your-space          # https://your-space.backlog.jp
BACKLOG_API_KEY=
BACKLOG_PROJECT_ID=
BACKLOG_ISSUE_TYPE_ID=
BACKLOG_PRIORITY_ID=

# --- Excel/ローカル（TICKET_BACKEND=excel のとき） ---
# data/tickets.csv に追記する。API 設定不要（オフライン検証用）。

# ── 報告書メール送信 ────────────────────────────────────────────────
# applescript(既定) = Mac のメールアプリに下書きを作成して表示（確認して送信）
# smtp              = SMTP で自動送信
MAIL_BACKEND=applescript
MAIL_TO=dev-team@example.com      # 開発チーム宛（カンマ区切りで複数可。空なら宛先は手入力）

# --- SMTP 自動送信を使う場合のみ（MAIL_BACKEND=smtp） ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-app-password   # Gmail はアプリパスワードを推奨
SMTP_USE_TLS=true
MAIL_FROM=your-address@gmail.com

# ── チャット連携（Slack） ───────────────────────────────────────────
# 対応: slack（既定）。Teams / LINE WORKS はアダプタ差し替えで拡張可。
CHAT_BACKEND=slack
SLACK_BOT_TOKEN=xoxb-...          # chat:write, files:read
SLACK_SIGNING_SECRET=             # リクエスト署名検証用

# ── サーバ ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8600
